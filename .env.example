# Front-end mode
VITE_API_MODE=mock
VITE_FORCE_API_ERROR=false
VITE_ENABLE_MOCK_FAILURE=false

# Vite proxy target for ESL BFF
VITE_BFF_TARGET=http://127.0.0.1:8787

# ESL BFF server
BFF_PORT=8787
LOG_LEVEL=info
ESL_ENABLE_JOBS=true
ESL_RETENTION_INTERVAL_MS=43200000
ESL_HOST=https://esl.greendisplay.cn
ESL_CLIENT_ID=20254235
ESL_SIGN=80805202542351f1b5
ESL_STORE_CODE=20254235
ESL_IS_BASE64=0

# Persistence
BFF_PERSISTENCE_MODE=sqlite
BFF_DATA_DIR=
BFF_BACKUP_ENABLED=true
BFF_BACKUP_INTERVAL_MS=86400000
BFF_BACKUP_RETENTION_COUNT=7

# Auth
BFF_AUTH_ENABLED=false
JWT_ACCESS_SECRET=replace_with_secure_access_secret
JWT_REFRESH_SECRET=replace_with_secure_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BFF_DEFAULT_ADMIN_EMAIL=admin@etiqueta.local
BFF_DEFAULT_ADMIN_PASSWORD=Admin@123

# Observability
METRICS_ENABLED=true
ESL_COMMAND_LOG_RETENTION_DAYS=30
ESL_DEAD_LETTER_RETENTION_DAYS=30
